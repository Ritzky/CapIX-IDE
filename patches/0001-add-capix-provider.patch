# CapixIDE patch — add Capix as a first-class provider in Void's settings types.
#
# This patch is applied by scripts/rebrand.sh on top of the Void source after
# the caps-sensitive rename. It inserts "capix" into the ProviderName union and
# modelCapabilities so the chat panel Settings UI shows "Capix (self-hosted)"
# as a pre-listed provider (not just under openAICompatible).
#
# Patches use VSCodium-style unified diff format. Apply with:
#   cd vscode && git apply ../patches/0001-add-capix-provider.patch
#
# If the patch fails to apply cleanly (e.g. Void's settings types changed
# upstream), resolve manually — the insertion points are clearly marked.

diff --git a/src/vs/workbench/contrib/capix/common/voidSettingsTypes.ts b/src/vs/workbench/contrib/capix/common/voidSettingsTypes.ts
--- a/src/vs/workbench/contrib/capix/common/voidSettingsTypes.ts
+++ b/src/vs/workbench/contrib/capix/common/voidSettingsTypes.ts
@@ -1,3 +1,3 @@
-// ProviderName type (around line where the union is defined)
-export type ProviderName = 'anthropic' | 'openAI' | 'deepseek' | 'openRouter' | 'ollama' | 'vLLM' | 'liteLLM' | 'lmStudio' | 'openAICompatible' | 'gemini' | 'groq' | 'xAI' | 'mistral' | 'googleVertex' | 'microsoftAzure' | 'awsBedrock'
+export type ProviderName = 'capix' | 'anthropic' | 'openAI' | 'deepseek' | 'openRouter' | 'ollama' | 'vLLM' | 'liteLLM' | 'lmStudio' | 'openAICompatible' | 'gemini' | 'groq' | 'xAI' | 'mistral' | 'googleVertex' | 'microsoftAzure' | 'awsBedrock'

diff --git a/src/vs/workbench/contrib/capix/common/modelCapabilities.ts b/src/vs/workbench/contrib/capix/common/modelCapabilities.ts
--- a/src/vs/workbench/contrib/capix/common/modelCapabilities.ts
+++ b/src/vs/workbench/contrib/capix/common/modelCapabilities.ts
@@ -1,3 +1,18 @@
+// Capix (self-hosted Capix LLM endpoint) — the default provider for CapixIDE.
+// Reuses the openAICompatible SDK path under the hood (sendLLMMessage.impl.ts).
+export const capixProviderDefaults = {
+  // Shown in the Settings UI dropdown, first position.
+  label: 'Capix (self-hosted endpoint)',
+  // Placeholder shown when the field is empty — guides the user to their deploy.
+  endpointPlaceholder: 'https://your-capix-endpoint/v1',
+  endpointLabel: 'Base URL (from capix.network/cloud/llm)',
+  apiKeyLabel: 'Capix API key (cpxllm_…)',
+  // The default settings entry shape; voidSettingsService merges this on first run.
+  requiresApiKey: true,
+  openAICompatible: true,
+  // Models are added dynamically by the user (their deployed model label).
+  hasDynamicModels: true,
+}
+
 // In defaultProviderSettings, insert 'capix' as the FIRST key so it's the
 // default selected provider on a fresh CapixIDE install:
 //
